# AI project workspace (keep only instructions tracked)
workspace/*
!workspace/AGENTS.md
!workspace/README.md

# Logs / traces
*.log
logs/

# Python
__pycache__/
*.pyc

# Coverage / test artifacts
coverage.out
cover.out
*.test

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
